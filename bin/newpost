#!/bin/bash

# newpost — scaffold a post skeleton for today's session
# usage: newpost <slug>

if [ -z "$1" ]; then
    echo "usage: newpost <slug>"
    echo "example: newpost day6-chmod"
    exit 1
fi

SLUG=$1
DATE=$(date +%Y-%m-%d)
POSTS_DIR=~/bootcamp/posts
FILE="$POSTS_DIR/$DATE-$SLUG.md"

mkdir -p "$POSTS_DIR"

if [ -e "$FILE" ]; then
    echo "file already exists: $FILE"
    exit 1
fi

cat > "$FILE" <<EOF
# $DATE — $SLUG

## LinkedIn

**Hook:**

**Body:**

**CTA:**

---

## X — long version

---

## X — short version

EOF

echo "created: $FILE"
